# ─────────────────────────────────────────────────────────────
#  LevMarket — Environment Variables
# ─────────────────────────────────────────────────────────────
#  Copy this file to .env.local and fill in the values.
#  NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# Vault contract on Polygon (already deployed)
NEXT_PUBLIC_VAULT_ADDRESS=0xB0B97F13a214D173bBAFd63a635b5216BdAdBaf4

# Polygon RPC — use your own Alchemy/Infura key for reliability
POLYGON_RPC_URL=https://polygon-rpc.com

# ─── Polymarket Server Wallet ───────────────────────────────
# This is the wallet that signs orders on Polymarket.
# It must be funded with USDC on Polygon + have Polymarket API access.
# Generate a new wallet:  cast wallet new   (requires Foundry)
POLYMARKET_PRIVATE_KEY=YOUR_NEW_SERVER_WALLET_PRIVATE_KEY_HERE
POLYMARKET_FUNDER_ADDRESS=YOUR_NEW_SERVER_WALLET_PUBLIC_ADDRESS_HERE

# ─── Polymarket Token IDs (optional — auto-discovered if blank) ──
# If left blank, the app auto-fetches them from the Polymarket Gamma API.
NEXT_PUBLIC_POLYMARKET_TOKEN_ID_YES=
NEXT_PUBLIC_POLYMARKET_TOKEN_ID_NO=
