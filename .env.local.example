# Copy this file to .env.local and fill in your values

# Deployed LeveragedVault contract address on Polygon
NEXT_PUBLIC_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# Polymarket CLOB token IDs for the YES and NO outcome tokens
NEXT_PUBLIC_POLYMARKET_TOKEN_ID_YES=
NEXT_PUBLIC_POLYMARKET_TOKEN_ID_NO=

# Server-side: private key of the wallet used to sign Polymarket orders + vault borrows/repays
POLYMARKET_PRIVATE_KEY=

# Server-side: funder/margin wallet address (used by Polymarket CLOB client)
POLYMARKET_FUNDER_ADDRESS=

# Polygon RPC URL (e.g. from Alchemy or Infura)
POLYGON_RPC_URL=https://polygon-rpc.com
